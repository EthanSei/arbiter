# Database (Supabase Postgres)
DATABASE_URL=postgresql+asyncpg://postgres:<password>@<host>:5432/postgres

# Kalshi (public endpoints work without auth)
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2

# Polymarket
POLYMARKET_CLOB_BASE=https://clob.polymarket.com
POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com

# Alerts — Discord
DISCORD_WEBHOOK_URL=

# Alerts — SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# Anthropic (future — not used in V1)
ANTHROPIC_API_KEY=

# Scanning parameters
POLL_INTERVAL_SECONDS=300
EV_THRESHOLD=0.05
KELLY_FRACTION=0.25
MAX_MARKETS_PER_POLL=200
FEE_RATE=0.01

# Health check
HEALTH_PORT=8080

# Model weights path
MODEL_WEIGHTS_PATH=models/arbiter_lgbm.pkl